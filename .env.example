# =============================================================================
# PHÁT TRIỂN (development)
# =============================================================================

# Database — local PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/perfume_db?schema=public"
# DIRECT_URL: local có thể trùng DATABASE_URL. Production (Neon) phải khác — xem section dưới.
DIRECT_URL="postgresql://postgres:password@localhost:5432/perfume_db?schema=public"

# NextAuth — BẮT BUỘC trên production
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Public site URL (dùng cho metadata, sitemap)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# OAUTH (optional — bật Google login khi có)
# =============================================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =============================================================================
# CLOUDINARY (optional — upload ảnh sản phẩm)
# Tạo tài khoản: https://cloudinary.com/users/register/free
# =============================================================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# =============================================================================
# EMAIL (Resend — gửi email xác nhận đơn)
# Tạo tài khoản: https://resend.com/signup
# Verify domain trước khi send ở production
# =============================================================================
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# =============================================================================
# THANH TOÁN (chưa tích hợp thật — placeholder)
# =============================================================================
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:3000/checkout/vnpay-return"

MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""

# =============================================================================
# PRODUCTION (chỉ set khi deploy)
# =============================================================================

# Neon PostgreSQL (2 URL):
#   - DATABASE_URL: pooled (có -pooler trong host) → dùng khi app chạy
#   - DIRECT_URL  : không pooled → Prisma dùng khi migrate / introspect
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.neon.tech/perfume?sslmode=require&pgbouncer=true&connect_timeout=15"
# DIRECT_URL="postgresql://user:pass@ep-xxx.neon.tech/perfume?sslmode=require"

# Rate limiting — cho multi-instance (Vercel serverless), dùng Upstash Redis thay vì in-memory
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Sentry — monitoring
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
